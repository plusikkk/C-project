<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClassesManager.Pages.SubjectDetailsPage"
             Title="{Binding Subject.Name}"
             x:Name="subjectDetailsPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="{Binding Subject.Name}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="{Binding Subject.FieldOfKnowledge, StringFormat='Field: {0}'}" FontSize="16" />
            <Label Text="{Binding Subject.ECTS, StringFormat='ECTS: {0}'}" FontSize="16" />
            <Label Text="{Binding Subject.TotalDuration, StringFormat='Total Duration: {0} mins'}" FontSize="16" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10,0,10"/>

            <Label Text="Lessons list" FontSize="20" FontAttributes="Bold" />

            <Button Text="+ Add Lesson" 
                    Command="{Binding AddClassCommand}" 
                    BackgroundColor="#512BD4" TextColor="White" FontAttributes="Bold" CornerRadius="8" />

            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10" Margin="0,5,0,5">
                <SearchBar Grid.Column="0" Placeholder="Search lessons..." Text="{Binding SearchQuery, Mode=TwoWay}" />
                <Picker Grid.Column="1" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}" WidthRequest="150" />
            </Grid>

            <CollectionView ItemsSource="{Binding FilteredClasses}"
                            SelectionMode="Single" 
                            SelectedItem="{Binding SelectedClass, Mode=TwoWay}"
                            SelectionChangedCommand="{Binding GoToClassCommand}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,5,0,10" Padding="15" CornerRadius="10" HasShadow="True">
                            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">

                                <VerticalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="{Binding Theme}" FontSize="18" FontAttributes="Bold" />
                                    <Label Text="{Binding Date, StringFormat='Date: {0}'}" FontSize="14" TextColor="DarkSlateGray" />
                                    <Label Text="{Binding Type, StringFormat='Type: {0}'}" FontSize="14" TextColor="DarkSlateGray" />
                                </VerticalStackLayout>

                                <Button Grid.Column="1" Text="edit" BackgroundColor="Transparent" TextColor="Blue" FontSize="16" VerticalOptions="Center"
                                        Command="{Binding BindingContext.EditClassCommand, Source={x:Reference subjectDetailsPage}}" CommandParameter="{Binding .}" />

                                <Button Grid.Column="2" Text="delete" BackgroundColor="Transparent" TextColor="Red" FontSize="16" VerticalOptions="Center"
                                        Command="{Binding BindingContext.DeleteClassCommand, Source={x:Reference subjectDetailsPage}}" CommandParameter="{Binding .}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>