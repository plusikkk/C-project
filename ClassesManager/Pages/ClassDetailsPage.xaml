<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClassesManager.Pages.ClassDetailsPage"
             Title="Lesson details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Information about the lesson" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />

            <Frame BackgroundColor="#F8F9FA" CornerRadius="12" Padding="20" HasShadow="True">
                <Grid RowSpacing="15" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Text="Theme:" FontAttributes="Bold" TextColor="Gray" />
                    <Label Grid.Row="0" Grid.Column="1" x:Name="lblTheme" FontSize="16" FontAttributes="Bold" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Type of lesson:" FontAttributes="Bold" TextColor="Gray" />
                    <Label Grid.Row="1" Grid.Column="1" x:Name="lblType" FontSize="16" />

                    <Label Grid.Row="2" Grid.Column="0" Text="Date:" FontAttributes="Bold" TextColor="Gray" />
                    <Label Grid.Row="2" Grid.Column="1" x:Name="lblDate" FontSize="16" />

                    <Label Grid.Row="3" Grid.Column="0" Text="Time:" FontAttributes="Bold" TextColor="Gray" />
                    <Label Grid.Row="3" Grid.Column="1" x:Name="lblTime" FontSize="16" />

                    <Label Grid.Row="4" Grid.Column="0" Text="Duration:" FontAttributes="Bold" TextColor="Gray" />
                    <Label Grid.Row="4" Grid.Column="1" x:Name="lblDuration" FontSize="16" TextColor="DarkBlue" FontAttributes="Bold" />
                </Grid>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>