<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClassesManager.Pages.ClassesCreatePage"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Theme of Lesson:" FontAttributes="Bold" />
            <Entry Text="{Binding Theme}" Placeholder="Enter theme..." />

            <Label Text="Type of Lesson:" FontAttributes="Bold" />
            <Picker ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}" />

            <Label Text="Date:" FontAttributes="Bold" />
            <DatePicker Date="{Binding Date}" />

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <VerticalStackLayout Grid.Column="0" Spacing="5">
                    <Label Text="Start Time:" FontAttributes="Bold" />
                    <TimePicker Time="{Binding StartTime}" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="5">
                    <Label Text="End Time:" FontAttributes="Bold" />
                    <TimePicker Time="{Binding EndTime}" />
                </VerticalStackLayout>
            </Grid>

            <Button Text="Save Lesson" 
                    Command="{Binding SaveCommand}"
                    BackgroundColor="Green" TextColor="White" Margin="0,20,0,0" 
                    FontAttributes="Bold" CornerRadius="8" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>